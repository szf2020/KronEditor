{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "KronEditor",
    "version": "0.1.0",
    "identifier": "com.plceditor.app",
    "build": {
        "beforeDevCommand": "npm run web",
        "beforeBuildCommand": "npm run build:web",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "KronEditor",
                "width": 1200,
                "height": 800,
                "decorations": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": [
            "resources/include/*",
            "resources/arm/aarch64/*",
            "resources/arm/armv7/*",
            "resources/arm/CortexM/M0/*",
            "resources/arm/CortexM/M4/*",
            "resources/arm/CortexM/M7/*"
        ],
        "icon": [
            "../images/icons/32x32.png",
            "../images/icons/128x128.png",
            "../images/icons/128x128@2x.png",
            "../images/icons/512x512.png",
            "../images/icons/icon.icns",
            "../images/icons/icon.ico"
        ]
    }
}