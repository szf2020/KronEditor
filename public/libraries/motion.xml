<?xml version="1.0" encoding="UTF-8"?>
<Library>
  <Category name="MOTION">
    <!-- 3.1  MC_Power — Enable / Disable power stage (PLCopen TC2 Part 1 v2.0) -->
    <Block type="MC_Power" description="Enable axis power stage" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"           type="AXIS_REF" />
        <Variable name="Enable"         type="BOOL"     default="FALSE" />
        <Variable name="EnablePositive" type="BOOL"     default="TRUE" />
        <Variable name="EnableNegative" type="BOOL"     default="TRUE" />
      </Inputs>
      <Outputs>
        <Variable name="Status"  type="BOOL" />
        <Variable name="Valid"   type="BOOL" />
        <Variable name="Error"   type="BOOL" />
        <Variable name="ErrorID" type="WORD" />
      </Outputs>
    </Block>

    <!-- 3.2  MC_Home -->
    <Block type="MC_Home" description="Execute homing sequence" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"     type="AXIS_REF" />
        <Variable name="Execute"  type="BOOL"  default="FALSE" />
        <Variable name="Position" type="REAL"  default="0.0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- 3.3  MC_Stop -->
    <Block type="MC_Stop" description="Controlled emergency stop" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"         type="AXIS_REF" />
        <Variable name="Execute"      type="BOOL"  default="FALSE" />
        <Variable name="Deceleration" type="REAL"  default="100.0" />
        <Variable name="Jerk"         type="REAL"  default="0.0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- 3.4  MC_Halt -->
    <Block type="MC_Halt" description="Controlled stop to Standstill" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"         type="AXIS_REF" />
        <Variable name="Execute"      type="BOOL"  default="FALSE" />
        <Variable name="Deceleration" type="REAL"  default="100.0" />
        <Variable name="Jerk"         type="REAL"  default="0.0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- 3.5  MC_MoveAbsolute -->
    <Block type="MC_MoveAbsolute" description="Move to absolute position" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"         type="AXIS_REF" />
        <Variable name="Execute"      type="BOOL"  default="FALSE" />
        <Variable name="Position"     type="REAL"  default="0.0" />
        <Variable name="Velocity"     type="REAL"  default="10.0" />
        <Variable name="Acceleration" type="REAL"  default="100.0" />
        <Variable name="Deceleration" type="REAL"  default="100.0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- 3.6  MC_MoveRelative -->
    <Block type="MC_MoveRelative" description="Move by relative distance" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"         type="AXIS_REF" />
        <Variable name="Execute"      type="BOOL"  default="FALSE" />
        <Variable name="Distance"     type="REAL"  default="0.0" />
        <Variable name="Velocity"     type="REAL"  default="10.0" />
        <Variable name="Acceleration" type="REAL"  default="100.0" />
        <Variable name="Deceleration" type="REAL"  default="100.0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- 3.9  MC_MoveVelocity -->
    <Block type="MC_MoveVelocity" description="Continuous velocity motion" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"         type="AXIS_REF" />
        <Variable name="Execute"      type="BOOL"  default="FALSE" />
        <Variable name="Velocity"     type="REAL"  default="10.0" />
        <Variable name="Acceleration" type="REAL"  default="100.0" />
        <Variable name="Deceleration" type="REAL"  default="100.0" />
      </Inputs>
      <Outputs>
        <Variable name="InVelocity"     type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- 3.31  MC_Reset -->
    <Block type="MC_Reset" description="Reset axis from ErrorStop" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"    type="AXIS_REF" />
        <Variable name="Execute" type="BOOL"  default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Done"    type="BOOL" />
        <Variable name="Busy"    type="BOOL" />
        <Variable name="Error"   type="BOOL" />
        <Variable name="ErrorID" type="WORD" />
      </Outputs>
    </Block>

    <!-- Read / Diagnostic blocks -->
    <Block type="MC_ReadActualPosition" description="Read actual axis position" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"   type="AXIS_REF" />
        <Variable name="Enable" type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"    type="BOOL" />
        <Variable name="Busy"     type="BOOL" />
        <Variable name="Error"    type="BOOL" />
        <Variable name="ErrorID"  type="WORD" />
        <Variable name="Position" type="REAL" />
      </Outputs>
    </Block>

    <Block type="MC_ReadActualVelocity" description="Read actual axis velocity" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"   type="AXIS_REF" />
        <Variable name="Enable" type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"     type="BOOL" />
        <Variable name="Busy"      type="BOOL" />
        <Variable name="Error"     type="BOOL" />
        <Variable name="ErrorID"   type="WORD" />
        <Variable name="Velocity"  type="REAL" />
      </Outputs>
    </Block>

    <Block type="MC_ReadStatus" description="Read axis state diagram status" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"   type="AXIS_REF" />
        <Variable name="Enable" type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"              type="BOOL" />
        <Variable name="Busy"               type="BOOL" />
        <Variable name="Error"              type="BOOL" />
        <Variable name="ErrorID"            type="WORD" />
        <Variable name="ErrorStop"          type="BOOL" />
        <Variable name="Disabled"           type="BOOL" />
        <Variable name="Stopping"           type="BOOL" />
        <Variable name="Homing"             type="BOOL" />
        <Variable name="Standstill"         type="BOOL" />
        <Variable name="DiscreteMotion"     type="BOOL" />
        <Variable name="ContinuousMotion"   type="BOOL" />
        <Variable name="SynchronizedMotion" type="BOOL" />
      </Outputs>
    </Block>

    <Block type="MC_ReadAxisError" description="Read axis-level error code" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"   type="AXIS_REF" />
        <Variable name="Enable" type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"       type="BOOL" />
        <Variable name="Busy"        type="BOOL" />
        <Variable name="Error"       type="BOOL" />
        <Variable name="ErrorID"     type="WORD" />
        <Variable name="AxisErrorID" type="WORD" />
      </Outputs>
    </Block>

    <Block type="MC_SetOverride" description="Set velocity/acceleration override" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"       type="AXIS_REF" />
        <Variable name="Enable"     type="BOOL"  default="FALSE" />
        <Variable name="VelFactor"  type="REAL"  default="1.0" />
        <Variable name="AccFactor"  type="REAL"  default="1.0" />
        <Variable name="JerkFactor" type="REAL"  default="1.0" />
      </Inputs>
      <Outputs>
        <Variable name="Enabled"  type="BOOL" />
        <Variable name="Busy"     type="BOOL" />
        <Variable name="Error"    type="BOOL" />
        <Variable name="ErrorID"  type="WORD" />
      </Outputs>
    </Block>
  </Category>
</Library>
